<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/warehouseSelect.css">
    <title>Document</title>
</head>

<body>
    <nav>
        <div class="logo">
            <img src="/images/logo-pic.svg" class="logo-img">
            <div>
                <h1 class="easymanage" style="color: #1750AC;">EASYMANAGE</h1>
                <h3 style="color: #E67E22;">WAREHOUSE MANAGEMENT SYSTEM</h3>
            </div>
        </div>

        <div class="text-select">
            <div class="text-left">
                <h1 style="font-size: 48px;">เลือกคลังสินค้า</h1>
                <p style="font-size: 28px; margin-top: 5%;">โปรดเลือกคลังสินค้าที่ต้องการจัดการ</p>
            </div>

            <div class="add-btn">
                <a href=""><button type="submit">+ เพิ่มคลังสินค้า</button></a>
            </div>
        </div>
    </nav>

    <div class="container">
        <% data.forEach(item => { %>
            <div class="card">
                <img src="/images/select-warehouse-pic.svg">
                <h1><%=item.warehouse_name%></h1>
                <input type="hidden" value="<%=item.warehouse_id%>">
                <a href="/" style="text-decoration: none; width: 100%;"><button style="padding-left: 20%; padding-right: 20%">เลือก</button></a>
            </div>
        <% }) %>
    </div>
</body>

</html>