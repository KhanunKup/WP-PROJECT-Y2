<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เพิ่มสินค้า</title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/add-product.css">
    <%- include("partials/icon.ejs") %>
</head>
<body>

    <%- include("partials/navbar.ejs") %>

    <main class="container">
        
        <div class="form-container">
            <div class="form-layout">
                
                <div class="form-left">
                    <input type="file" id="imageInput" accept="image/*" style="display: none;">

                    <div class="image-upload-box orange-box">
                        <div class="upload-icon">
                            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                <polyline points="21 15 16 10 5 21"></polyline>
                            </svg>
                        </div>
                        <h2>เลือกรูปภาพ</h2>
                    </div>

                    <button class="btn-upload">อัปโหลดภาพสินค้า</button>

                    <div class="tag-group" id="tagsContainer">
                        </div>
                </div>

                <div class="form-right">
                    <h2 class="form-title">รายละเอียดสินค้า:</h2>

                    <div class="input-group">
                        <label>ชนิดสินค้า:</label>
                        <select id="productSelect" class="input-area" style="cursor: pointer;">
                            <option value="new">สร้างสินค้าชนิดใหม่...</option>
                            </select>
                    </div>
                    
                    <div class="input-group">
                        <label>ชื่อสินค้า:</label>
                        <input type="text" placeholder="กรุณากรอกชื่อสินค้า..." class="input-area">
                    </div>
                    
                    <div class="input-group">
                        <label>หมวดหมู่:</label>
                        <div style="display: flex; gap: 10px; flex: 1;">
                            <select id="categoryInput" class="input-light-blue" style="cursor: pointer; width: 100%; height: 45px; padding: 0 15px;">
                                <option value="" disabled selected>เลือกหมวดหมู่สินค้า...</option>
                            </select>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>ต้นทุน:</label>
                        <div class="input-wrapper-unit">
                            <input type="number" id="inputCost" placeholder="0" min="0" class="input-area">
                            <span class="unit-text">บาท</span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>ราคาขาย:</label>
                        <div class="input-wrapper-unit">
                            <input type="number" id="inputPrice" placeholder="0" min="0" class="input-area">
                            <span class="unit-text">บาท</span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>สภาพสินค้า:</label>
                        <div class="condition-group">
                            <button type="button" class="btn-condition btn-perfect active" value="ปกติ" >สภาพสมบูรณ์</button>
                            <button type="button" class="btn-condition btn-damaged" value="เสียหาย" >ชำรุด/เสียหาย</button>
                        </div>
                    </div>

                    <div class="input-group align-top">
                        <label>ที่จัดเก็บ:</label>
                        <textarea rows="3" class="input-area" placeholder="กรุณากรอกที่จัดเก็บ..."></textarea>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button class="btn-cancel">✖ ยกเลิก</button>
                <button class="btn-save">✎ บันทึกสินค้า</button>
            </div>

        </div>
    </main>
    <script src="/sweetalert/sweetalert2.all.min.js"></script>
    <script src="/js/add-product.js"></script>

</body>
</html>