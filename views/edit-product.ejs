<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>แก้ไขสินค้าหลัก</title>
    <link rel="stylesheet" href="/css/edit-product.css">
</head>
<body>
    <%- include("partials/navbar.ejs") %>

    <main class="container">
        <div class="form-container">
            <div class="form-layout">
                
                <div class="form-left">
                    <input type="file" id="imageInput" accept="image/*" style="display: none;">

                    <div class="image-upload-box orange-box" id="uploadBox" style="cursor: pointer;">
                        <div class="upload-icon">
                            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                <polyline points="21 15 16 10 5 21"></polyline>
                            </svg>
                        </div>
                        <h2>อัปโหลดภาพสินค้า</h2>
                    </div>
                    <button class="btn-upload" id="btnUpload">เปลี่ยนรูปภาพ</button>
                </div>

                <div class="form-right">
                    <h2 class="form-title">แก้ไขรายละเอียดสินค้า:</h2>

                    <div class="input-group">
                        <label>ชื่อสินค้า:</label>
                        <input type="text" id="inputName" placeholder="กรุณากรอกชื่อสินค้า..." class="input-area">
                    </div>
                    
                    <div class="input-group">
                        <label>หมวดหมู่:</label>
                        <select id="categoryInput" class="input-light-blue" style="cursor: pointer;">
                            <option value="" disabled selected>เลือกหมวดหมู่สินค้า...</option>
                            <% categories.forEach(function(cat) { %>
                                <option value="<%= cat.category_id %>"><%= cat.category_name %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="input-group">
                        <label>ต้นทุน:</label>
                        <div class="input-wrapper-unit">
                            <input type="number" id="inputCost" placeholder="0" min="0" class="input-area">
                            <span class="unit-text">บาท</span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>ราคาขาย:</label>
                        <div class="input-wrapper-unit">
                            <input type="number" id="inputPrice" placeholder="0" min="0" class="input-area">
                            <span class="unit-text">บาท</span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>จำนวนรวม:</label>
                        <div class="input-wrapper-unit">
                            <input type="number" id="inputTotalStock" class="input-area" readonly style="background-color: #f1f5f9; cursor: not-allowed;">
                            <span class="unit-text">ชิ้น</span>
                        </div>
                    </div>

                </div>
            </div>

            <div class="form-actions">
                <button class="btn-cancel" id="btnCancel">✖ ยกเลิก</button>
                <button class="btn-save" id="btnSave">✎ บันทึกรายละเอียดสินค้า</button>
            </div>

        </div>
    </main>

    <script src="/js/edit-product.js"></script>
</body>
</html>