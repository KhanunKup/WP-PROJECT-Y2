<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>
    <%- include("partials/dashboard.ejs") %>
        <div class="info-zone">
            <h1>EASYMANAGE <span style="font-family: Kanit;">ระบบจัดการสินค้า</span></h1>

            <div class="dashboard-grid">
                <div class="card">
                    <div class="card-header">
                        <img src="/images/dashboard-db-pic.svg">
                        <span>จำนวนสินค้าทั้งหมด</span> 
                    </div>
                    <div class="card-value">67,911</div>
                    <div class="card-subtext text-green">+150 <span class="icon-gray">เดือนนี้</span></div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <img src="/images/dashboard-alert-pic.svg">
                        <span>จำนวนสินค้าใกล้หมด</span>
                    </div>
                    <div class="card-value">67 <span class="unit">รายการ</span></div>
                    <div class="card-subtext">เพิ่มมา <span class="text-red">+3</span></div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <img src="/images/dashboard-trending-up-pic.svg">
                        <span>จำนวนสินค้าที่เพิ่มมา</span>
                    </div>
                    <div class="card-subtext" style="margin-bottom: 15px;">เดือนนี้</div>
                    <div class="card-value text-green">+67 <span class="unit">รายการ</span></div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <img src="/images/dashboard-trending-down-pic.svg">
                        <span>จำนวนสินค้าที่ออกไป</span> 
                    </div>
                    <div class="card-subtext" style="margin-bottom: 15px;">เดือนนี้</div>
                    <div class="card-value text-red">-67 <span class="unit">รายการ</span></div>
                </div>
            </div>

            <div class="bottom-grid">
                <div class="panel">
                    <h2 class="panel-title">รายการสินค้าใกล้หมด</h2>
                    <table>
                        <thead>
                            <tr>
                                <th>ชื่อสินค้า</th>
                                <th>ชนิดของสินค้า</th>
                                <th>จำนวน</th>
                                <th>สถานะ</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- wait for implement -->
                            <tr>
                                <td>MacBook Pro 16"</td>
                                <td>laptop</td>
                                <td>3</td>
                                <td>กำลังเติมสินค้า</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- wait for implement -->
                <div class="right-column">
                    <div class="panel">
                        <h2 class="panel-title">จำนวนสินค้าแบ่งตามประเภท</h2>
                        <div class="chart-placeholder"></div>
                    </div>

                    <!-- wait for implement -->
                    <div class="panel">
                        <h2 class="panel-title">กิจกรรมล่าสุด</h2>
                        <ul class="activity-list">
                            <li>10:30 น. ....</li>
                            <li>09:15 น. ....</li>
                            <li>05:45 น. ....</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
</body>
</html>